<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>TOEIC Part 1 - Listening: Mô tả Tranh</title>
  </head>
  <body>
    <outline text="TOEIC Part 1 - Listening: Mô tả Tranh">

      <outline text="1. Thông tin chung">
        <outline text="Hình thức: Xem tranh → Nghe 4 câu A/B/C/D → Chọn câu mô tả đúng nhất"/>
        <outline text="Số lượng: 6 câu (câu 1–6)"/>
        <outline text="Kỹ năng: Nghe hiểu tiếng Anh cơ bản trong cuộc sống hằng ngày"/>
        <outline text="Lưu ý quan trọng">
          <outline text="4 câu mô tả KHÔNG được in ra"/>
          <outline text="Chỉ nghe được 1 lần duy nhất"/>
          <outline text="Phải chọn đáp án ngay sau khi nghe"/>
        </outline>
      </outline>

      <outline text="2. Các dạng câu hỏi">

        <outline text="Dạng 1: Tranh tả NGƯỜI">
          <outline text="Đặc điểm: Cả 4 đáp án đều nói về người trong tranh"/>
          <outline text="Tập trung vào: Hành động, tư thế, hoạt động của nhân vật"/>
          <outline text="Ví dụ (Test 1 - Q01)">
            <outline text="Tranh: Người phụ nữ"/>
            <outline text="A. The woman is talking on the phone"/>
            <outline text="B. The woman is using her cell phone ✓"/>
            <outline text="C. The woman is typing on the laptop"/>
            <outline text="D. The woman is writing in her notebook"/>
          </outline>
          <outline text="Từ vựng cần chú ý">
            <outline text="Động từ hành động: talking, using, typing, writing, sitting, standing..."/>
            <outline text="Thì hiện tại tiếp diễn (is/are + V-ing)"/>
          </outline>
        </outline>

        <outline text="Dạng 2: Tranh tả VẬT / CẢNH">
          <outline text="Đặc điểm: Cả 4 đáp án đều mô tả sự vật trong tranh"/>
          <outline text="Tập trung vào: Vị trí, số lượng, trạng thái của đồ vật"/>
          <outline text="Ví dụ (Test 1 - Q05)">
            <outline text="Tranh: Ngoài trời có bàn ghế"/>
            <outline text="A. There are some tables and chairs outdoors ✓"/>
            <outline text="B. There are some people sitting at the tables"/>
            <outline text="C. There are plastic umbrellas on the tables"/>
            <outline text="D. There are many flowers in the garden"/>
          </outline>
          <outline text="Từ vựng cần chú ý">
            <outline text="There is / There are..."/>
            <outline text="Giới từ vị trí: on, in, at, next to, beside, behind..."/>
            <outline text="Tính từ mô tả: empty, full, crowded, clean..."/>
          </outline>
        </outline>

        <outline text="Dạng 3: Tranh tả CẢ NGƯỜI và VẬT / CẢNH">
          <outline text="Đặc điểm: Đáp án hỗn hợp — có câu tả người, có câu tả vật"/>
          <outline text="Lưu ý: Đáp án đúng có thể là câu tả vật, không nhất thiết tả người"/>
          <outline text="Ví dụ (Test 5 - Q03)">
            <outline text="Tranh: Người đàn ông bên xe có tuyết"/>
            <outline text="A. His car door is covered in snow ✓  → tả VẬT"/>
            <outline text="B. He is driving a car in the snow  → tả người (sai)"/>
            <outline text="C. He has already shoveled the snow off the roof  → tả người (sai)"/>
            <outline text="D. He is playing with friends in the snow  → tả người (sai)"/>
          </outline>
          <outline text="Chiến thuật: Không bỏ qua đáp án tả vật khi tranh có người"/>
        </outline>

      </outline>

      <outline text="3. Cách làm bài (3 bước)">

        <outline text="Bước 1: Xác định dạng tranh">
          <outline text="Tranh chỉ có người?"/>
          <outline text="Tranh chỉ có vật / cảnh?"/>
          <outline text="Tranh có cả người lẫn vật / cảnh?"/>
        </outline>

        <outline text="Bước 2: Quan sát và phán đoán TRƯỚC khi nghe">
          <outline text="Nhân vật đang làm gì?"/>
          <outline text="Sự vật đang ở đâu? Trạng thái thế nào?"/>
          <outline text="Dự đoán từ vựng có thể xuất hiện"/>
          <outline text="Tự đặt câu mô tả trong đầu"/>
        </outline>

        <outline text="Bước 3: Nghe và loại trừ">
          <outline text="Nghe hết cả 4 đáp án, kể cả khi đã nghĩ ra đáp án đúng"/>
          <outline text="Luôn nghe hết câu — không dừng giữa chừng"/>
          <outline text="Dùng phương pháp loại trừ: gạch bỏ câu sai"/>
          <outline text="Các bẫy thường gặp">
            <outline text="Nghe giống âm nhưng nghĩa khác (homophones)"/>
            <outline text="Mô tả đúng chi tiết phụ, sai chi tiết chính"/>
            <outline text="Dùng từ xuất hiện trong tranh nhưng câu sai ngữ nghĩa"/>
          </outline>
        </outline>

      </outline>

      <outline text="4. Bẫy thường gặp và cách tránh">
        <outline text="Bẫy từ vựng gần âm">
          <outline text="VD: writing ↔ riding, cooking ↔ looking"/>
          <outline text="Cách tránh: Nghe kỹ phụ âm đầu và đuôi"/>
        </outline>
        <outline text="Bẫy hành động chưa xảy ra">
          <outline text="VD: He is about to sit ↔ He is sitting"/>
          <outline text="Cách tránh: Quan sát kỹ hành động trong tranh"/>
        </outline>
        <outline text="Bẫy vật không có trong tranh">
          <outline text="Câu nhắc đến đồ vật KHÔNG xuất hiện trong hình"/>
          <outline text="Cách tránh: Kiểm tra từng chi tiết tranh trước"/>
        </outline>
        <outline text="Bẫy vị trí sai">
          <outline text="VD: on the table ↔ under the table"/>
          <outline text="Cách tránh: Ghi nhớ giới từ vị trí thường gặp"/>
        </outline>
      </outline>

      <outline text="5. Từ vựng thường gặp trong Part 1">
        <outline text="Động từ hành động người">
          <outline text="talking, walking, sitting, standing, carrying, holding"/>
          <outline text="reading, writing, typing, pointing, looking at"/>
          <outline text="loading, unloading, arranging, stacking"/>
        </outline>
        <outline text="Mô tả vật / cảnh">
          <outline text="There is / There are..."/>
          <outline text="is placed / is located / is displayed"/>
          <outline text="is covered with / is filled with / is surrounded by"/>
        </outline>
        <outline text="Giới từ vị trí">
          <outline text="on, in, at, next to, beside, behind, in front of, across from"/>
        </outline>
      </outline>

    </outline>
  </body>
</opml>
